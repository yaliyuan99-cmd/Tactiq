# Tactiq backend — Supabase configuration
#
# 1. Create a free project at https://supabase.com
# 2. In the dashboard: Project Settings → API
# 3. Copy the values below, then save this file as `.env` (without `.example`)
# 4. Restart the dev server (`npm run dev`)
#
# The anon/public key is safe to expose in a browser app — it only grants the
# access allowed by your Row-Level-Security policies (see supabase/migrations).
# NEVER put the `service_role` key in here; that key bypasses RLS.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional — admin access in LOCAL (no-Supabase) mode only.
# Comma-separated emails treated as admins when the app runs on localStorage.
# With Supabase configured, admin status comes from profiles.is_admin instead
# (flip it with the SQL at the bottom of supabase/migrations/0002_orders_and_admin.sql).
# If left blank in local mode, the first account created on the machine is admin.
# VITE_ADMIN_EMAILS=you@example.com
